FROM confluentinc/cp-kafka-connect:7.5.0

USER root
RUN microdnf update && \
    microdnf install -y unzip curl ca-certificates && \
    microdnf clean all

# 1. 검증된 주소로 다운로드
RUN curl -L "https://github.com/Aiven-Open/cloud-storage-connectors-for-apache-kafka/releases/download/v3.4.2/azure-sink-connector-for-apache-kafka-3.4.2.zip" -o /tmp/azure-aiven.zip

# 2. [수정] 특정 패턴 대신 전체를 임시 폴더에 풀고 필요한 JAR만 이동
# v3.4.2는 폴더 구조가 다르기 때문에 안전하게 전체 해제 후 이동합니다.
RUN mkdir -p /tmp/extract && \
    unzip -o /tmp/azure-aiven.zip -d /tmp/extract && \
    mkdir -p /usr/share/confluent-hub-components/azure-blob-aiven/lib && \
    # 추출된 폴더 내의 모든 .jar 파일을 한 곳으로 모읍니다.
    find /tmp/extract -name "*.jar" -exec cp {} /usr/share/confluent-hub-components/azure-blob-aiven/lib/ \;

# 3. 권한 정리 및 임시파일 삭제
RUN chown -R appuser:appuser /usr/share/confluent-hub-components && \
    rm -rf /tmp/azure-aiven.zip /tmp/extract

USER appuser