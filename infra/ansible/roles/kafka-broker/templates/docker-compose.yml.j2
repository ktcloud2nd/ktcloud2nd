version: '3.8'
services:
{% for i in [1, 2, 3] %}
  kafka{{ i }}:
    image: confluentinc/cp-kafka:7.5.0
    container_name: kafka{{ i }}
    ports:
      - "{{ 9093 + i }}:{{ 9093 + i }}"
    environment:
      KAFKA_NODE_ID: {{ i }}
      KAFKA_PROCESS_ROLES: 'broker,controller'
      
      KAFKA_LISTENERS: 'INTERNAL://:9092,EXTERNAL://:{{ 9093 + i }},CONTROLLER://:9093'
      KAFKA_CONTROLLER_QUORUM_VOTERS: '1@kafka1:9093,2@kafka2:9093,3@kafka3:9093'
      KAFKA_ADVERTISED_LISTENERS: 'INTERNAL://kafka{{ i }}:9092,EXTERNAL://{{ ansible_default_ipv4.address }}:{{ 9093 + i }}'
      
      KAFKA_INTER_BROKER_LISTENER_NAME: 'INTERNAL'
      KAFKA_CONTROLLER_LISTENER_NAMES: 'CONTROLLER'
      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: 'INTERNAL:PLAINTEXT,EXTERNAL:PLAINTEXT,CONTROLLER:PLAINTEXT'
      
      CLUSTER_ID: 'MkU3OEVBNTcwNTJENDM2Qk'
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: 3
      KAFKA_GROUP_INITIAL_REBALANCE_DELAY_MS: 0
      KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR: 3
      KAFKA_TRANSACTION_STATE_LOG_MIN_ISR: 2
    volumes:
      - ./data/kafka{{ i }}:/var/lib/kafka/data
{% endfor %}